# ── LLM ──────────────────────────────────────────
# Choose one: openai | anthropic | gemini | local
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here        # also used for embeddings
GOOGLE_API_KEY=your_google_api_key_here        # also supports GEMINI_API_KEY

# ── Vector Database ───────────────────────────────
# Choose one: pinecone | chroma
VECTOR_DB=chroma
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=rag-knowledge-base
PINECONE_ENVIRONMENT=us-east-1-aws

# ChromaDB (local dev, no key needed)
CHROMA_PERSIST_DIR=./data/chroma_db

# ── Embeddings ────────────────────────────────────
# Choose one: openai | huggingface
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_MODEL=text-embedding-3-small         # if using openai

# ── Reranker ──────────────────────────────────────
COHERE_API_KEY=your_cohere_api_key_here
USE_RERANKER=false                               # set true when you have a Cohere key

# ── RAG Settings ──────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5
TOP_K_RERANK=3
MAX_CONVERSATION_HISTORY=5

# ── App ───────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_SECRET_KEY=change_me_in_production
